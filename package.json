{
  "name": "smartfurni-webapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build --experimental-build-mode=compile",
    "start": "next start -p $PORT",
    "lint": "next lint",
    "test": "vitest run",
    "media:migrate:download": "node --env-file=.env.production scripts/migrate-cloudinary-media.mjs --download",
    "media:migrate:apply": "node --env-file=.env.production scripts/migrate-cloudinary-media.mjs --apply-db",
    "media:migrate:direct": "node scripts/migrate-cloudinary-media.mjs --direct",
    "media:migrate:recover": "node scripts/migrate-cloudinary-media.mjs --recover-local",
    "app:sync": "cap sync",
    "app:assets": "node scripts/generate-smart-bed-mobile-assets.mjs",
    "app:ios": "cap open ios",
    "app:android": "cap open android",
    "app:doctor": "cap doctor"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@capacitor-community/bluetooth-le": "^7.2.0",
    "@capacitor/android": "^7.6.8",
    "@capacitor/cli": "^7.6.8",
    "@capacitor/core": "^7.6.8",
    "@capacitor/ios": "^7.6.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.21.0",
    "@types/nodemailer": "^7.0.11",
    "@types/nprogress": "^0.2.3",
    "@types/pg": "^8.18.0",
    "ai": "^5.0.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.2",
    "google-ads-api": "^21.0.0",
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "jssip": "^3.10.0",
    "lucide-react": "^0.475.0",
    "mysql2": "^3.20.0",
    "next": "15.5.12",
    "nodemailer": "^8.0.2",
    "nprogress": "^0.2.0",
    "openai": "^6.44.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-image-crop": "^11.0.10",
    "resend": "^6.9.4",
    "sharp": "^0.33.0",
    "tailwind-merge": "^2.6.0",
    "zca-js": "^2.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "15.2.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
