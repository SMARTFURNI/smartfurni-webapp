# ============================================================================
# SmartFurni CRM - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/smartfurni_db

# ============================================================================
# Gemini 2.5 Flash API Configuration
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.7

# ============================================================================
# Email Service Configuration
# ============================================================================
# Choose one: 'gmail', 'sendgrid', 'smtp'
EMAIL_PROVIDER=gmail

# Gmail Configuration (if using Gmail)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_FROM_EMAIL=noreply@smartfurni.com

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@smartfurni.com

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@smartfurni.com

# ============================================================================
# Zalo API Configuration
# ============================================================================
ZALO_OFFICIAL_ACCOUNT_ID=your_zalo_oa_id
ZALO_ACCESS_TOKEN=your_zalo_access_token
ZALO_WEBHOOK_SECRET=your_zalo_webhook_secret
ZALO_API_ENDPOINT=https://openapi.zalo.me/v2.0

# ============================================================================
# Redis Configuration (for Queue and Caching)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/smartfurni/ai-agent.log

# ============================================================================
# Monitoring & Error Tracking
# ============================================================================
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development

# ============================================================================
# API Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000

# Email API Rate Limit
EMAIL_RATE_LIMIT_PER_HOUR=500

# Zalo API Rate Limit
ZALO_RATE_LIMIT_PER_HOUR=1000

# Gemini API Rate Limit
GEMINI_RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# AI Agent Feature Flags
# ============================================================================
FEATURE_EMAIL_AUTOMATION=true
FEATURE_ZALO_CHATBOT=true
FEATURE_LEAD_SCORING=true
FEATURE_TASK_AUTOMATION=true

# ============================================================================
# Email Automation Settings
# ============================================================================
EMAIL_AUTO_SEND_DELAY_MINUTES=5
EMAIL_BATCH_SIZE=50
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_SECONDS=60

# ============================================================================
# Lead Scoring Settings
# ============================================================================
LEAD_SCORING_BATCH_SCHEDULE=0 2 * * *
LEAD_SCORING_ENGAGEMENT_WEIGHT=0.35
LEAD_SCORING_RECENCY_WEIGHT=0.25
LEAD_SCORING_SOURCE_WEIGHT=0.20
LEAD_SCORING_COMPANY_WEIGHT=0.20

# ============================================================================
# Task Automation Settings
# ============================================================================
TASK_AUTO_GENERATION_ENABLED=true
TASK_ASSIGNMENT_STRATEGY=workload_based
TASK_MAX_PER_STAFF=10
TASK_REMINDER_SCHEDULE=0 * * * *

# ============================================================================
# Zalo Chatbot Settings
# ============================================================================
ZALO_AUTO_REPLY_ENABLED=true
ZALO_ESCALATION_THRESHOLD=3
ZALO_RESPONSE_TIMEOUT_SECONDS=30

# ============================================================================
# Notification Settings
# ============================================================================
NOTIFICATION_CHANNELS=email,in_app
NOTIFICATION_TASK_ASSIGNED=true
NOTIFICATION_LEAD_SCORED=true
NOTIFICATION_EMAIL_SENT=false

# ============================================================================
# Security Settings
# ============================================================================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=7d
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# ============================================================================
# External Services
# ============================================================================
# AWS S3 (for file storage)
AWS_S3_BUCKET=smartfurni-uploads
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database Migration
# ============================================================================
RUN_MIGRATIONS_ON_START=true
MIGRATION_PATH=./migrations
