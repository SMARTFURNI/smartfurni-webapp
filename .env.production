# ============================================
# AI Agent - API Configuration
# ============================================

# Gemini 2.5 Flash API
GEMINI_API_KEY=${OPENAI_API_KEY}
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2000

# Email Provider - Gmail/SendGrid
EMAIL_PROVIDER=gmail
GMAIL_USER=smartfurni.crm@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM_NAME=SmartFurni CRM
EMAIL_FROM_ADDRESS=smartfurni.crm@gmail.com

# Zalo API
ZALO_OA_ID=your_zalo_oa_id_here
ZALO_ACCESS_TOKEN=your_zalo_access_token_here
ZALO_SECRET_KEY=your_zalo_secret_key_here
ZALO_WEBHOOK_URL=https://smartfurni-webapp-production.up.railway.app/api/ai-agent/zalo/webhook

# Facebook Lead Ads API
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_LEAD_FORM_ID=your_lead_form_id_here
FACEBOOK_WEBHOOK_URL=https://smartfurni-webapp-production.up.railway.app/api/ai-agent/facebook/webhook

# TikTok Lead API
TIKTOK_BUSINESS_ACCOUNT_ID=your_tiktok_account_id_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_WEBHOOK_URL=https://smartfurni-webapp-production.up.railway.app/api/ai-agent/tiktok/webhook

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smartfurni_ai_agent

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
GEMINI_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Feature Flags
ENABLE_EMAIL_AUTOMATION=true
ENABLE_ZALO_CHATBOT=true
ENABLE_LEAD_SCORING=true
ENABLE_TASK_AUTOMATION=true
ENABLE_BATCH_PROCESSING=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# AI Agent Settings
AI_AGENT_BATCH_SIZE=50
AI_AGENT_RETRY_ATTEMPTS=3
AI_AGENT_RETRY_DELAY_MS=1000
